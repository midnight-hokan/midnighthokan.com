---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 8);

const tagColors = {
  'ai': 'cyan',
  'hardware': 'green',
  'maker': 'amber',
  'deep-dive': 'purple'
};
const tagNames = {
  'ai': 'AI实验',
  'hardware': '硬件折腾',
  'maker': '造物计划',
  'deep-dive': '深度解读'
};
---
<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
  <Header />
  <main>
    <section class="hero">
      <div class="hero-top">
        <div>
          <div class="sys-label">MIDNIGHT HOKAN</div>
          <h1>🌙 深夜补完计划</h1>
          <p class="tagline">白天搬砖，深夜炼丹。</p>
          <p class="subtitle">用自己的设备，跑自己的模型，造自己的东西。</p>
        </div>
        <div class="fleet-badge">
          <div class="badge-label">LOBSTER FLEET</div>
          <div class="badge-count">7 NODES</div>
        </div>
      </div>
    </section>

    <section class="tags-bar">
      <a href="/blog" class="tag-pill all">全部</a>
      <a href="/blog" class="tag-pill cyan">AI实验</a>
      <a href="/blog" class="tag-pill green">硬件折腾</a>
      <a href="/blog" class="tag-pill amber">造物计划</a>
      <a href="/blog" class="tag-pill purple">深度解读</a>
    </section>

    <section class="stats">
      <div class="stat-card">
        <div class="stat-label">ARTICLES</div>
        <div class="stat-value cyan">018</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">PROJECTS</div>
        <div class="stat-value green">4</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">DEVICES</div>
        <div class="stat-value amber">7</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">GPU VRAM</div>
        <div class="stat-value">120G</div>
      </div>
    </section>

    <section class="latest">
      <h2 class="section-title">$ cat latest.log</h2>
      <div class="post-list">
        {posts.map((post) => (
          <a href={"/blog/" + post.id + "/"} class="post-item">
            <span class="post-date">{post.data.pubDate.toISOString().slice(0, 10)}</span>
            <span class="post-title">{post.data.title}</span>
          </a>
        ))}
      </div>
      <a href="/blog" class="view-all">cd /blog/ →</a>
    </section>

    <section class="about-teaser">
      <h2 class="section-title">$ whoami</h2>
      <p>白天上班，深夜炼丹。一个普通人的 AI 折腾日常。</p>
      <p>运营一支叫「龙虾舰队」的本地 AI 推理集群，七台设备各司其职，从 96GB 显存的工作站到树莓派，全部自托管。</p>
      <p>同时在造机器人、做内容、写代码。这个站记录这一切。</p>
      <a href="/about" class="view-all">cat /about →</a>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .hero {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--border);
  }
  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .sys-label {
    font-size: 0.7rem;
    letter-spacing: 4px;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  h1 { font-size: 1.8rem; font-weight: 500; margin-bottom: 0.5rem; }
  .tagline { color: var(--text-secondary); font-size: 0.95rem; }
  .subtitle { color: var(--text-muted); font-size: 0.8rem; margin-top: 0.3rem; }
  .fleet-badge {
    text-align: right;
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .badge-count {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--accent-green);
    margin-top: 4px;
  }

  .tags-bar {
    display: flex;
    gap: 8px;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .tag-pill {
    font-size: 0.7rem;
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    letter-spacing: 1px;
  }
  .tag-pill:hover { text-decoration: none; }
  .tag-pill.all { border-color: var(--text-secondary); color: var(--text-primary); }
  .tag-pill.cyan:hover, .tag-pill.cyan { border-color: var(--accent-cyan); color: var(--accent-cyan); }
  .tag-pill.green:hover, .tag-pill.green { border-color: var(--accent-green); color: var(--accent-green); }
  .tag-pill.amber:hover, .tag-pill.amber { border-color: var(--accent-amber); color: var(--accent-amber); }
  .tag-pill.purple:hover, .tag-pill.purple { border-color: #b388ff; color: #b388ff; }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
  }
  .stat-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 2px;
  }
  .stat-value {
    font-size: 1.4rem;
    font-weight: 500;
    margin-top: 4px;
    color: var(--text-primary);
  }
  .stat-value.cyan { color: var(--accent-cyan); }
  .stat-value.green { color: var(--accent-green); }
  .stat-value.amber { color: var(--accent-amber); }

  .latest, .about-teaser {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .section-title {
    font-size: 0.85rem;
    color: var(--accent-cyan);
    font-weight: 400;
    margin-bottom: 1rem;
  }
  .post-list { display: flex; flex-direction: column; gap: 4px; }
  .post-item {
    display: flex;
    gap: 1rem;
    padding: 8px 0;
    font-size: 0.85rem;
    color: var(--text-primary);
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .post-item:hover { text-decoration: none; background: var(--bg-card); margin: 0 -8px; padding: 8px; border-radius: 4px; }
  .post-date { color: var(--text-muted); font-size: 0.75rem; min-width: 90px; }
  .post-title { color: var(--text-primary); }
  .view-all {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--accent-cyan);
  }
  .about-teaser p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
    line-height: 1.8;
  }

  @media (max-width: 600px) {
    .hero-top { flex-direction: column; }
    .fleet-badge { text-align: left; margin-top: 1rem; }
    .stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
